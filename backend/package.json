{
  "name": "@pr-outreach/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn src/server.ts",
    "start:test": "cross-env NODE_ENV=test ts-node-dev --respawn src/server.ts",
    "start:staging": "cross-env NODE_ENV=staging node dist/server.js",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "migrate": "cross-env NODE_ENV=development ts-node-dev src/config/migrate.ts",
    "migrate:test": "cross-env NODE_ENV=test ts-node-dev src/config/migrate.ts"
  },
