# ============================================
# PR Outreach Intelligence — Environment Config
# ============================================
# Copy this file to .env.<stage> and fill in your values.
# Supported stages: .env.development, .env.test, .env.staging, .env.production

# ---------- App ----------
PORT=3000
NODE_ENV=development          # development | test | staging | production

# ---------- PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---------- JWT ----------
JWT_SECRET=                   # min 16 chars — generate with: openssl rand -base64 32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:5173

# ---------- AI Provider ----------
AI_PROVIDER=openai            # openai | gemini
AI_PROVIDER_API_KEY=          # OpenAI API key (when AI_PROVIDER=openai)
AI_PROVIDER_MODEL=gpt-4o-mini

# ---------- Gemini (when AI_PROVIDER=gemini) ----------
GEMINI_API_KEY=               # Google AI API key
GEMINI_MODEL=gemini-2.0-flash

# ---------- Email Provider ----------
EMAIL_PROVIDER=console        # resend | console (console = log to stdout, no real send)
RESEND_API_KEY=               # Resend API key (when EMAIL_PROVIDER=resend)
EMAIL_FROM_ADDRESS=onboarding@resend.dev
EMAIL_FROM_NAME=PR Outreach
