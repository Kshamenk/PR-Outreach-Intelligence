# ============================================
# PR Outreach Intelligence — Environment Config
# ============================================
# Copy this file to .env (or .env.<stage>) and fill in your values.
# Supported stages: .env (prod), .env.development, .env.test, .env.staging

# ---------- App ----------
PORT=3000
NODE_ENV=development          # development | test | staging | production

# ---------- PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---------- JWT ----------
JWT_SECRET=                   # min 16 chars — generate with: openssl rand -base64 32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:5173
